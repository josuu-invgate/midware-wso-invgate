# =============================================================================
#  Integração Workspace ONE (UEM) -> InvGate Asset Management
#  Copie este arquivo para ".env" e preencha as credenciais.
#  As URLs já vêm com os valores STANDARD; ajuste ao seu tenant.
#  (Este arquivo é um TEMPLATE: só placeholders, vai ao git. O .env real NÃO.)
# =============================================================================

# -----------------------------------------------------------------------------
#  WORKSPACE ONE UEM  (origem dos dispositivos móveis - API MDM)
# -----------------------------------------------------------------------------
# Host base do tenant. Ex: https://asXXX.awmdm.com  ou  https://cnXXX.awmdm.com
WS1_BASE_URL=https://as258.awmdm.com
# Autenticação Basic (usuário de API do Workspace ONE)
WS1_USERNAME=CHANGE_ME
WS1_PASSWORD=CHANGE_ME
# API Key do tenant -> header "aw-tenant-code" (Settings > System > Advanced > API > REST API)
WS1_TENANT_CODE=CHANGE_ME
# Versão da API de devices/search (Accept: application/json;version=N).
# Deixe VAZIO => application/json (v1, a mais completa para devices/search; v2 tem gaps).
WS1_API_VERSION=
# (Opcional) Organization Group ID numérico para limitar a busca (parâmetro lgid).
# Em tenants grandes / contas com escopo evita o erro 500. Riachuelo (prod) = 14407.
WS1_ORGANIZATION_GROUP_ID=
# Plataformas a importar, separadas por vírgula. Só se mantêm as MÓVEIS (Apple, Android);
# valores não-móveis (ex. AppleOsX, WindowsPc) são ignorados. Vazio = todas as móveis.
WS1_PLATFORMS=Apple,Android
# Tamanho de página ao paginar devices/search (default da API=10; recomendado 500)
WS1_PAGE_SIZE=500
# Importar só dispositivos com EnrollmentStatus=Enrolled (true/false)
WS1_ONLY_ENROLLED=true
# Buscar armazenamento (total/disponível), inclusive Android, com 1 chamada extra por
# device ao detalhe GET /api/mdm/devices/{id} (TotalStorageBytes/AvailableStorageBytes).
# Custo: +1 request por device. Necessário para storage em Android.
WS1_FETCH_STORAGE=false

# -----------------------------------------------------------------------------
#  INVGATE ASSET MANAGEMENT  (destino - Public API, OAuth2 client_credentials)
# -----------------------------------------------------------------------------
IGAM_PROTOCOL=https
IGAM_INSTANCE_URL=tua-instancia.is.cloud.invgate.net
IGAM_PORT=443
IGAM_CLIENT_ID=CHANGE_ME
IGAM_CLIENT_SECRET=CHANGE_ME
IGAM_GRANT_TYPE=client_credentials

# Dica: para alternar entre teste e produção, mantenha um bloco comentado e troque:
#   # PRODUÇÃO (Riachuelo)
#   # IGAM_INSTANCE_URL=riachuelo.is.cloud.invgate.net
#   # IGAM_CLIENT_ID=CHANGE_ME
#   # IGAM_CLIENT_SECRET=CHANGE_ME

# -----------------------------------------------------------------------------
#  OPÇÕES DE SINCRONIZAÇÃO
# -----------------------------------------------------------------------------
# Nomes de asset_type: os nativos costumam ser minúsculos (phone, tablet) e o create é
# case-insensitive. O UI mostra "Telefone", mas enviar "Telefone"/"Smartphone" dá 500.
IGAM_TABLET_TYPE=Tablet
IGAM_PHONE_TYPE=Phone
# Estilo de auth do token OAuth2: auto | post | basic
IGAM_AUTH_STYLE=auto
# Lifecycle status padrão ao criar o asset (ver GET /public-api/asset-status/).
# Riachuelo: 2=Ativo (NÃO use 1=Merged, é interno).
IGAM_DEFAULT_STATUS_ID=2
# (Opcional) Location padrão se não der para resolver (ver GET /public-api/locations/)
IGAM_DEFAULT_LOCATION_ID=
# DRY_RUN=true => NÃO escreve no InvGate, só mostra o que faria. Ponha false para criar de verdade.
DRY_RUN=true
# UPDATE_EXISTING=true => se o serial já existe no InvGate, atualiza (PATCH). false => ignora.
UPDATE_EXISTING=true
# RESOLVE_OWNER=true => tenta resolver o owner por email (UserEmailAddress -> Person). Sem match, omite.
RESOLVE_OWNER=false
# VERIFY_TLS=false só para ambientes de teste com certificados self-signed.
VERIFY_TLS=true

# -----------------------------------------------------------------------------
#  AVANÇADO (opcional) — só descomente se precisar mudar os defaults
# -----------------------------------------------------------------------------
# Arquivo do mapa de custom fields (default: custom_fields.json)
# IGAM_CUSTOM_FIELDS_FILE=custom_fields.json
# Arquivo do mapa de locations (default: location_map.json)
# IGAM_LOCATION_MAP_FILE=location_map.json
# ci_type usado no endpoint de custom fields (default: phone)
# IGAM_CI_TYPE=phone
